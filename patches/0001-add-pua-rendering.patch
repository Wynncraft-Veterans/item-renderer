@@ -0,0 +1,73 @@
+/**
+ * PUA-encoded item OG image route.
+ *
+ * Mirrors `server/api/_og/item/[slug].get.ts` but takes a PUA-encoded
+ * item string (Wynntils' private-use-area item-share format) instead of
+ * a base-item slug. Renders the same `ItemCard` OG component with the
+ * rolled identification values from the decoded item.
+ *
+ * Used by the Wynncraft Veterans "nazbot" Discord bridge to attach an
+ * item-card image when a guild chat message contains a PUA-encoded item.
+ */
+
+import { Buffer } from 'node:buffer'
+import { createCdnClient } from '~/lib/data/cdn-client'
+import { loadSearchData } from '~/lib/items-search/load-search-data'
+import { buildSlugIndex, resolveSlug } from '~/lib/items-search/slug'
+import { parseIdString } from '~/lib/wynntils/decode'
+import { getIdKeys } from '~/lib/wynntils/id-keys'
+import { extractRolledMeta } from '~/lib/wynntils/rolled-to-card'
+import type { SearchItem } from '~/lib/items-search/types'
+
+function slugify(name: string): string {
+  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
+}
+
+// Module-level cache: items rarely change; re-fetch only when gameVersion
+// changes. Mirrors the [slug].get.ts route.
+let itemCache: { gameVersion: string, index: Map<string, SearchItem[]> } | null = null
+
+export default defineEventHandler(async (event) => {
+  const encoded = getRouterParam(event, 'encoded')
+  if (!encoded)
+    throw createError({ statusCode: 400, statusMessage: 'Missing encoded parameter' })
+
+  let blocks
+  try {
+    blocks = parseIdString(encoded)
+  }
+  catch (err) {
+    throw createError({ statusCode: 400, statusMessage: `Decode failed: ${(err as Error).message}` })
+  }
+
+  // Pull the item name out of the decoded blocks.
+  let nameStr: string | null = null
+  for (const b of blocks) {
+    if (b.name === 'NameData') {
+      nameStr = b.nameStr
+      break
+    }
+  }
+  if (!nameStr)
+    throw createError({ statusCode: 422, statusMessage: 'No NameData block in encoded item' })
+
+  const config = useRuntimeConfig()
+  const client = createCdnClient(config.public.cdnBaseUrl)
+
+  if (!itemCache) {
+    const data = await loadSearchData(client)
+    itemCache = { gameVersion: data.gameVersion, index: buildSlugIndex(data.items) }
+  }
+
+  const baseItem = resolveSlug(itemCache.index, slugify(nameStr), nameStr)
+  if (!baseItem)
+    throw createError({ statusCode: 404, statusMessage: `Unknown item: ${nameStr}` })
+
+  const idKeys = await getIdKeys()
+  const itemMeta = extractRolledMeta(baseItem, blocks, idKeys)
+  const ogPath = buildOgImagePath('ItemCard', itemMeta as Record<string, unknown>, `/items/${slugify(nameStr)}`)
+  const data = await $fetch<ArrayBuffer>(ogPath, { responseType: 'arrayBuffer' })
+
+  setResponseHeader(event, 'content-type', 'image/png')
+  return Buffer.from(data)
+})
