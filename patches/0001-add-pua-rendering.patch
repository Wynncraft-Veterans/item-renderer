+/**
+ * Adapter: turn a PUA-decoded item (parseIdString blocks) plus the matched
+ * base SearchItem into the structured `ItemMeta` props that
+ * `app/components/OgImage/ItemCard.takumi.vue` already accepts.
+ *
+ * The strategy is to reuse `extractItemMeta(baseItem)` for everything the
+ * base item carries (tier, icon, lore, defence, dps, sp, ...), then
+ * override `idRows` with rolled values + roll-percent colors derived from
+ * the decoded identifications. Powders, shiny, reroll count are not
+ * surfaced today — `ItemCard.takumi.vue`'s `powderSlots` is the slot
+ * count (which is a base-item property), not the filled count.
+ */
+
+import type { Block } from './decode'
+import type { ItemMeta, IdRow } from '~/lib/items/item-meta'
+import type { SearchItem } from '~/lib/items-search/types'
+import { humanizeField, isInverted } from '~/lib/data/identifications'
+import { extractItemMeta } from '~/lib/items/item-meta'
+import { ID_BAD_COLOR, ID_GOOD_COLOR, idIsGood } from '~/lib/items/tooltip'
+import { rollPercent } from './roll-percent'
+
+// Wynncraft / Minecraft chat-colour palette for roll-percent tiers.
+// Mirrors roll-percent.ts's CSS-var ladder (red / gold / yellow / green /
+// aqua) — Takumi can't resolve CSS vars, so we inline hex.
+const ROLL_RED = '#FF5555'
+const ROLL_GOLD = '#FFAA00'
+const ROLL_YELLOW = '#FFFF55'
+const ROLL_GREEN = '#55FF55'
+const ROLL_AQUA = '#55FFFF'
+
+function rollPctToHex(pct: number | null, isGood: boolean): string {
+  if (pct == null)
+    return isGood ? ID_GOOD_COLOR : ID_BAD_COLOR
+  if (pct < 20)
+    return ROLL_RED
+  if (pct < 50)
+    return ROLL_GOLD
+  if (pct < 80)
+    return ROLL_YELLOW
+  if (pct < 100)
+    return ROLL_GREEN
+  return ROLL_AQUA
+}
+
+function findNameBlock(blocks: Block[]): string | null {
+  for (const b of blocks) {
+    if (b.name === 'NameData')
+      return b.nameStr
+  }
+  return null
+}
+
+function findIdentBlock(blocks: Block[]) {
+  for (const b of blocks) {
+    if (b.name === 'IdentificationData')
+      return b
+  }
+  return null
+}
+
+/**
+ * Combine base-item display data with rolled identifications.
+ *
+ * @param baseItem  The SearchItem matched against the decoded NameData.
+ * @param blocks    The full Block[] from parseIdString.
+ * @param idKeys    Stat-id-byte → v3 API name map (from getIdKeys()).
+ */
+export function extractRolledMeta(
+  baseItem: SearchItem,
+  blocks: Block[],
+  idKeys: Map<number, string>,
+): ItemMeta {
+  const baseMeta = extractItemMeta(baseItem)
+
+  const identBlock = findIdentBlock(blocks)
+  if (!identBlock)
+    return baseMeta
+
+  const rolledRows: IdRow[] = []
+  for (const ent of identBlock.identifications) {
+    // Skip preid (unidentified) entries — they have no roll yet.
+    if (typeof ent.roll !== 'number')
+      continue
+    const v3Name = idKeys.get(ent.kind)
+    if (!v3Name)
+      continue
+    const range = baseItem.identifications[v3Name]
+    if (!range)
+      continue
+
+    const { label, unit } = humanizeField(v3Name)
+    const inverted = isInverted(v3Name)
+    const lo = Math.min(range.min, range.max)
+    const hi = Math.max(range.min, range.max)
+    const actual = Math.max(
+      lo,
+      Math.min(hi, Math.round(range.raw * (ent.roll / 100))),
+    )
+    const pct = rollPercent(actual, range)
+    const sign = actual > 0 ? '+' : ''
+    const valueText = `${sign}${actual}${unit}`
+    const pctText = pct == null ? '' : ` [${pct.toFixed(1)}%]`
+
+    rolledRows.push({
+      label,
+      left: '',
+      right: `${valueText}${pctText}`,
+      color: rollPctToHex(pct, idIsGood(actual, inverted)),
+    })
+  }
+
+  return { ...baseMeta, idRows: rolledRows }
+}
